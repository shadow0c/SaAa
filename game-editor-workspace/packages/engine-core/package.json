{
  "name": "@game-engine/core",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "default": "./dist/physics/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "default": "./dist/render/index.js"
    },
    "./network": {
      "types": "./dist/network/index.d.ts",
      "default": "./dist/network/index.js"
    },
    "./network/bridge": {
      "types": "./dist/network/bridge.d.ts",
      "default": "./dist/network/bridge.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "default": "./dist/assets/index.js"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "default": "./dist/engine/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "typescript": "^5.4.5"
  }
